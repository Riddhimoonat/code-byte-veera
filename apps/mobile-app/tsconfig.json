{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "jsx": "react-native",
    "baseUrl": ".",
    "paths": {
      "@screens/*": [
        "src/screens/*"
      ],
      "@components/*": [
        "src/components/*"
      ],
      "@services/*": [
        "src/services/*"
      ],
      "@hooks/*": [
        "src/hooks/*"
      ],
      "@types/*": [
        "src/types/*"
      ],
      "@constants/*": [
        "src/constants/*"
      ],
      "@tasks/*": [
        "src/tasks/*"
      ],
      "@react-navigation/*": [
        "node_modules/@react-navigation/*"
      ],
      "@react-navigation/bottom-tabs": [
        "node_modules/@react-navigation/bottom-tabs/lib/typescript/src/index.d.ts"
      ],
      "@react-navigation/native": [
        "node_modules/@react-navigation/native/lib/typescript/src/index.d.ts"
      ],
      "@react-navigation/native-stack": [
        "node_modules/@react-navigation/native-stack/lib/typescript/src/index.d.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ],
  "extends": "./node_modules/expo/tsconfig.base.json"
}
