# Veera Mobile App — Environment Variables
# Copy this to .env and fill in values
# The backend team will provide the production URL after deployment.

# Base URL for the Veera backend API (Node.js + Express)
EXPO_PUBLIC_API_BASE_URL=https://veera-core.onrender.com/api

# Set to 'true' to enable verbose logging in services
EXPO_PUBLIC_DEBUG_MODE=false
